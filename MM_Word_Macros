Attribute VB_Name = "MedMark"
Sub FixKeyboardLayout()
    Dim myText As String
    Dim newText As String
    Dim i As Long
    Dim c As String
    
    If Selection.Type = wdSelectionIP Then
        MsgBox "Please select some text first"
        Exit Sub
    End If
    
    myText = Selection.text
    newText = ""
    
    For i = 1 To Len(myText)
        c = Mid(myText, i, 1)
        newText = newText & ConvertChar(c)
    Next i
    
    Selection.text = newText
End Sub

