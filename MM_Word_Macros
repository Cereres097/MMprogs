Sub EnDates()
    
    With Selection.Find
        .ClearFormatting
        .Replacement.ClearFormatting
        .Forward = True
        .Wrap = wdFindContinue
        .MatchWildcards = True
        
        ' 1
        .text = "([0-9]{2})\.([0-9]{2})\.([0-9]{4})"
        .Replacement.text = "\1/\2/\3"
        .Execute Replace:=wdReplaceAll
        
        ' 2
        .text = "([0-9]{1})\.([0-9]{2})\.([0-9]{4})"
        .Replacement.text = "0\1/\2/\3"
        .Execute Replace:=wdReplaceAll
        
        ' 3
        .text = "([0-9]{2})\.([0-9]{1})\.([0-9]{4})"
        .Replacement.text = "\1/0\2/\3"
        .Execute Replace:=wdReplaceAll
        
        ' 4
        .text = "([0-9]{1})\.([0-9]{1})\.([0-9]{4})"
        .Replacement.text = "0\1/0\2/\3"
        .Execute Replace:=wdReplaceAll
    End With
    
    MsgBox "Готово", vbInformation
End Sub

